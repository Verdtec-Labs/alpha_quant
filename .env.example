# =============================================================================
# ALPHA-QUANT · .env
# Copia este ficheiro para .env e preenche com os teus dados reais
# NUNCA partilhes este ficheiro — contém credenciais
# =============================================================================

# ── MetaTrader 5 ──────────────────────────────────────────────────────────────
MT5_LOGIN=0                          # Número da conta demo (ex: 12345678)
MT5_PASSWORD=a_tua_password          # Palavra-passe da conta
MT5_SERVER=ICMarkets-Demo            # Nome exacto do servidor (ver MT5 → Ficheiro → Login)
# MT5_PATH deixa vazio para detecção automática, ou especifica:
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXX   # Obtém em: https://console.anthropic.com

# ── WhatsApp via Twilio (notificações no teu telemóvel) ──────────────────────
# Twilio sandbox é GRATUITO para testes. Setup em 5 min:
# 1. Regista em https://www.twilio.com (gratuito)
# 2. Vai a Messaging → Try it out → Send a WhatsApp message
# 3. Envia "join <palavra>" para o número Twilio do sandbox pelo teu WhatsApp
# 4. Copia Account SID e Auth Token do dashboard Twilio
# 5. WHATSAPP_FROM = número Twilio sandbox (começa com whatsapp:+1415...)
# 6. WHATSAPP_TO   = o teu número próprio (ex: whatsapp:+351912345678)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+351912345678

# ── Configuração (opcional — sobrepõe os defaults do config.py) ──────────────
# DEMO_MODE=true          # true = sem ordens reais (muda para false com cuidado)
# LOG_LEVEL=INFO          # DEBUG para mais detalhe
